{
  "name": "galset-api",
  "version": "1.0.0",
  "description": "Galset standalone API server",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "sync": "node ../scripts/sync-shared.js",
    "dev": "npm run sync && ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "npm run sync && tsc && tsc-alias && node -e \"const fs = require('fs'); try { fs.cpSync('src/emails', 'dist/emails', { recursive: true }); } catch (e) {}\"",
    "email": "email dev --dir src/emails"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.108.0",
    "ai": "^4.0.0",
    "bcrypt": "^5.1.1",
    "cohere-ai": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.0.0",
    "imagekit": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.0.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@react-email/ui": "^6.5.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.0.0",
    "drizzle-kit": "^0.31.10",
    "react-email": "^6.5.0",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
